# CA1416 - Platform compatibility (this is a Windows-only WinForms app)
dotnet_diagnostic.CA1416.severity = none

# CA1001 - Types that own disposable fields should be disposable
dotnet_diagnostic.CA1001.severity = none

# CA1033 - Interface methods should be callable by child types
dotnet_diagnostic.CA1033.severity = none

# CA1060 - Move P/Invokes to NativeMethods class
dotnet_diagnostic.CA1060.severity = none

# CA1063 - Implement IDisposable correctly
dotnet_diagnostic.CA1063.severity = none

# CA2002 - Do not lock on objects with weak identity
dotnet_diagnostic.CA2002.severity = none

# CA2022 - Avoid inexact read with Stream.Read
dotnet_diagnostic.CA2022.severity = none

# CA2200 - Rethrow to preserve stack details
dotnet_diagnostic.CA2200.severity = none

# CA2213 - Disposable fields should be disposed
dotnet_diagnostic.CA2213.severity = none

# SYSLIB0014 - WebRequest is obsolete
dotnet_diagnostic.SYSLIB0014.severity = none
